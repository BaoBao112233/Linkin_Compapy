# ── Copy file này thành .env và điền thông tin của bạn ──
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# Cookie-based auth (khuyến nghị – tránh lỗi CHALLENGE)
# Chạy "python get_cookie.py" để tự động lấy giá trị bên dưới
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=

# Scraping
HEADLESS=true
REQUEST_DELAY=2.5
MAX_COMPANIES=500
MAX_RETRIES=3

# Output
OUTPUT_DIR=output
