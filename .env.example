# ── Copy file này thành .env và điền thông tin của bạn ──
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# Cookie-based auth (khuyến nghị – tránh lỗi CHALLENGE)
# Chạy "python get_cookie.py" để tự động lấy giá trị bên dưới
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=

GROQ_API_KEY=your_groq_api_key_here

# ── Telegram Settings ──────────────────────────────────────────────────────
# Bot token (bắt buộc) – lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=8585500195:AAFj68fr3gPmNLeWGKP-2Og1Uxk9oN3lvaI

# Telethon – MTProto API (tuỳ chọn, cho phép search channel đầy đủ)
# Lấy tại https://my.telegram.org/apps > API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Số message tối đa đọc mỗi kênh (mặc định 200)
TELEGRAM_MAX_MESSAGES=200

# Scraping
HEADLESS=true
REQUEST_DELAY=2.5
MAX_COMPANIES=500
MAX_RETRIES=3

# Output
OUTPUT_DIR=output
